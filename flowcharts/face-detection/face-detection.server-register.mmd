flowchart TD
  Q["POST /dashboard/face-register {descriptor}"] --> R["Server: registerFace"]
  R --> S{"Session user + code + role?"}
  S -->|No| T["401 Unauthorized"]
  S -->|Yes| U["resolveUserModel(role)"]
  U --> V{"Model found?"}
  V -->|No| W["400 Unsupported role"]
  V -->|Yes| X["Validate descriptor array"]
  X --> Y{"Array? len==128? all numbers?"}
  Y -->|No| Z["400 Invalid descriptor"]
  Y -->|Yes| AB["Update user doc: push descriptor (keep last 5), set faceUploaded"]
  AB --> AC["200 success JSON"]
