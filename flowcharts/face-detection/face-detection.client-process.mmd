flowchart TD
  K["processFace(file)"] --> L["Convert file to image"]
  L --> M["Detect single face + landmarks + descriptor"]
  M --> N{"Detection found?"}
  N -->|No| O["Alert: no face detected"]
  N -->|Yes| P["descriptor = Array.from(detection.descriptor)"]
  P --> Q["POST /dashboard/face-register {descriptor}"]

  Q --> AD{"Client: res.ok?"}
  AD -->|No| AA["Client alert: error"]
  AD -->|Yes| AE["Alert success, disable input, reload"]
