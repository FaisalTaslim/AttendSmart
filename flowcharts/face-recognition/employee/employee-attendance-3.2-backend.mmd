flowchart TD
  A["POST /dashboard/employee/increment-attendance {code}"] --> B{"Employee code received?"}
  B -->|No| C["Error: Employee code is required"]
  B -->|Yes| D["Find employee by code"]
  D --> E{"Employee found?"}
  E -->|No| F["Stop (not found)"]
  E -->|Yes| G{"Active session for org + shift?"}
  G -->|No| H["Error: No active session"]
  G -->|Yes| I["Find matching Summary document"]
  I --> J{"Summary match and not already marked?"}
  J -->|Yes| K["Mark attendance (attended += 1)"]
  J -->|No| L["No matching document or already marked"]
  K --> M["Return success"]
  L --> M

  M --> N["Client continues loop until camera stops"]
