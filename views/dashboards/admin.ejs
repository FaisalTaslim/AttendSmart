  <script>
    function toggleHistoryRow(id) {
      const row = document.getElementById(id);
      const index = id.split('-').pop();
      let prefix;
      if (id.startsWith('emp')) prefix = 'emp-history-icon-';
      else if (id.startsWith('std-history')) prefix = 'std-history-icon-';
      else if (id.startsWith('std-summary')) prefix = 'std-summary-icon-';
      const icon = document.getElementById(prefix + index);
      const isHidden = row.style.display === 'none';
      row.style.display = isHidden ? 'table-row' : 'none';
      icon.textContent = isHidden ? '▼' : '▶';
    }
  </script>

