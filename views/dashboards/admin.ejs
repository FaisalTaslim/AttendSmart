<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard</title>
  <link rel="stylesheet" href="/css/global/theme/palette-II.css">
  <link rel="stylesheet" href="/css/global/ui-components/font-family.css">
  <link rel="stylesheet" href="/css/global/ui-components/font-size.css">
  <link rel="stylesheet" href="/css/global/ui-components/font-family.css">
  <link rel="stylesheet" href="/css/global/ui-components/scrollbar.css">
  <link rel="stylesheet" href="/css/global/layout/main.css">
  <link rel="stylesheet" href="/css/global/layout/header.css">
  <link rel="stylesheet" href="/css/global/layout/footer.css">
  <link rel="stylesheet" href="/css/global/ui-components/forms.css">
  <link rel="stylesheet" href="/css/global/ui-components/tables.css">
  <link rel="stylesheet" href="/css/global/ui-components/popup.css">
  <link rel="stylesheet" href="/css/global/layout/g-dashboard.css">
  <link rel="stylesheet" href="/css/page-specific/dashboard-2/admin.css">

  <script src="https://kit.fontawesome.com/f75c66b724.js" crossorigin="anonymous"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
</head>

<body>
  <% if (popupMessage) { %>
  <div id="popup" class="popup <%= popupType %> show">
    <%= popupMessage %>
  </div>
  <% } %>
  <header>
    <div class="logo">
      <h1 class="mobile-hidden gradient-text">AttendSmart</h1>
    </div>

    <nav class="nav-bar">
      <a href="/app" class="nav-links-property">Home</a>
      <a href="/auth/logout" class="nav-links-property">Logout</a>
      <a href="/guidebook" class="nav-links-property">GuideBook</a>
    </nav>

    <nav class="mobile-nav-container">
      <div class="nav-select outer-group">
        <select id="mobile-nav">
          <option value="" disabled selected>-- Navigate --</option>
          <option value="/">Home</option>
          <option value="/auth/logout">Logout</option>
          <option value="/guidebook">GuideBook</option>
        </select>
      </div>
    </nav>
  </header>
  <main>
    <section class="user-dashboard">
      <div class="headings-and-status">
        <div id="headings">
          <h3>Admin control centre</h3>
          <h2>Manage your organization from one modern dashboard</h2>
          <p>
            Everything from setup to reports is grouped below for faster access and cleaner
            workflows.
          </p>
        </div>
        <div id="status">
          <p>Setup: completed</p>
          <button id="account-info-btn">Account info</button>
        </div>
      </div>
      <div class="dashboard-navigation">
        <section class="card">
          <h3>Attendance</h3>
          <p id='start-session-btn'>Start Session</p>
          <p id="student-summary-btn">Student Summary</p>
          <p id="employee-summary-btn">Employee Summary</p>
          <p>Download Reports</p>
        </section>
        <section class="card">
          <h3>User Management</h3>
          <p>View Users</p>
          <p>Manage Users</p>
        </section>
        <section class="card">
          <h3>Academic configurations</h3>
          <p>Subjects</p>
          <p>Schedule</p>
        </section>
        <section class="card">
          <h3>Communication</h3>
          <p>Notice & System mails</p>
          <p>Support Requests</p>
        </section>
        <section class="card">
          <h3>Audit Log</h3>
          <p id="login-logs-btn">Login Logs</p>
          <p id="register-logs-btn">Registration Logs</p>
          <p id="active-employee-session-btn">Active Employee Session Logs</p>
          <p id="active-student-session-btn">Active Student Session Logs</p>
          <p id="employee-attendance-history-btn">Employee Attendance History Logs</p>
          <p id="student-attendance-history-btn">Student Attendance History Logs</p>
        </section>
      </div>
      <%if (!isSetupDone) { %>
      <div class="setup-uploads">
        <h2>Complete the setup</h2>
        <p>
          Read the <a href="/app/guideboook" class="link">guide</a> before you submit these csv files. Also feel free
          to reach out for <a href="/" class="link">support</a> if you need any help.
        </p>
        <div class="upload-container">
          <% if (orgType !=='corporate' && isSubjectsUploaded===false) { %>
          <div class="upload-card">
            <form id="subjectsForm" enctype="multipart/form-data">
              <input type="file" id="subjectsCsv" name="subjectsCsv" accept=".csv" hidden>

              <label for="subjectsCsv" class="upload-label">
                <div class="upload-content">
                  <div class="upload-icon"><i class="fa-solid fa-file-arrow-up"></i></div>
                  <p class="upload-title">Upload the subjects CSV file</p>
                  <p class="upload-subtitle">Only .csv files are supported</p>
                </div>
              </label>
            </form>
          </div>
          <% } %>

          <% if (isScheduleUploaded===false) { %>
          <div class="upload-card">
            <form id="scheduleForm" enctype="multipart/form-data">
              <input type="file" id="scheduleCsv" name="scheduleCsv" accept=".csv" hidden>

              <label for="scheduleCsv" class="upload-label">
                <div class="upload-content">
                  <div class="upload-icon"><i class="fa-solid fa-calendar-plus"></i>
                  </div>
                  <p class="upload-title">Upload the schedule CSV file</p>
                  <p class="upload-subtitle">Only .csv files are supported</p>
                </div>
              </label>
            </form>
          </div>
          <% } %>
        </div>
        <p class="tip">
          <b>Note:</b> You can later make changes in subjects and schedule list through settings
        </p>
      </div>
      <% } %>
    </section>
    <section class="dashboard-contents">
      <div class="overlay">
        <div class="session-form" id="session-form">
          <button id="sessionform-cancel">Go Back</button>
          <form action="/attendance/start-employee-session" method="POST">

            <div class="outer-group">
              <label>Shift</label>
              <select name="shift" required>
                <option value="day">Day</option>
                <option value="night">Night</option>
              </select>

            </div>
            <div class="outer-group">
              <label>Type</label>
              <select name="type" required>
                <option value="check-in">Check-in</option>
                <option value="check-out">Check-out</option>
              </select>
            </div>

            <button type="submit">Start Session</button>

          </form>
        </div>

        <div class="login-logs" id="login-logs">
          <button id="login-logs-cancel-btn">Go Back</button>
          <div class="log-table-header">
            <h2><i class="ti ti-login"></i> Login logs</h2>
          </div>
          <table class="log-table">
            <thead>
              <tr>
                <th>Status</th>
                <th>Name</th>
                <th>User ID</th>
                <th>Role</th>
                <th>Message</th>
                <th>Time</th>
              </tr>
            </thead>
            <tbody>
              <% if (loginLog && loginLog.length > 0) { %>
              <% loginLog.forEach(log => { %>
              <tr>
                <td data-label="Status">
                  <span class="badge badge-<%= log.type === 'success' ? 'success' : 'danger' %>">
                    <%= log.type %>
                  </span>
                </td>
                <td data-label="Name"><span class="name-text"><%= log.name %></span></td>
                <td data-label="User ID"><span class="id-text"><%= log.id %></span></td>
                <td data-label="Role"><span class="role-pill"><%= log.role %></span></td>
                <td data-label="Message"><span class="msg-text"><%= log.message %></span></td>
                <td data-label="Time"><span class="time-text"><%= new Date(log.createdAt).toLocaleString() %></span></td>
              </tr>
              <% }) %>
              <% } else { %>
              <tr>
                <td colspan="6" style="text-align:center; color: var(--color-text-secondary);">No login activity yet.</td>
              </tr>
              <% } %>
            </tbody>
          </table>
        </div>

        <div class="register-logs" id="register-logs">
          <button id="register-logs-cancel-btn">Go Back</button>
          <div class="log-table-header">
            <h2>Registration logs</h2>
            <p class="badge badge-success">Total: <span id="register-log-count"><%= registerLog.length %></span></p>
          </div>

          <div class="outer-group">
            <input type="text" id="register-search" placeholder="Search by name, ID, or email..." />
            <select id="register-role-filter">
              <option value="">All roles</option>
              <option value="admin">Admin</option>
              <option value="employee">Teacher</option>
              <option value="student">Student</option>
            </select>
            <select id="register-status-filter">
              <option value="">All statuses</option>
              <option value="success">Success</option>
              <option value="failed">Failed</option>
            </select>
            <select id="register-approval-filter">
              <option value="">All approval statuses</option>
              <option value="approved">Approved</option>
              <option value="rejected">Rejected</option>
              <option value="pending">Pending</option>
            </select>
          </div>

          <table class="log-table">
            <thead>
              <tr>
                <th>Status</th>
                <th>Name</th>
                <th>User ID</th>
                <th>Role</th>
                <th>Email</th>
                <th>Contact</th>
                <th>Message</th>
                <th>Time</th>
                <th>Approval Status</th>
              </tr>
            </thead>
            <tbody>
              <% if (registerLog && registerLog.length > 0) { %>
              <% registerLog.forEach(log => { %>
              <tr data-name="<%= log.name.toLowerCase() %>" data-id="<%= log.id.toLowerCase() %>" data-email="<%= log.email.toLowerCase() %>" data-role="<%= log.role %>" data-status="<%= log.type %>" data-approval="<%= log.approvalStatus || '' %>">
                <td data-label="Status">
                  <span class="badge badge-<%= log.type === 'success' ? 'success' : 'danger' %>">
                    <%= log.type %>
                  </span>
                </td>
                <td data-label="Name"><span class="name-text"><%= log.name %></span></td>
                <td data-label="User ID"><span class="id-text"><%= log.id %></span></td>
                <td data-label="Role"><span class="role-pill"><%= log.role %></span></td>
                <td data-label="Email"><span class="msg-text"><%= log.email %></span></td>
                <td data-label="Contact"><span class="msg-text"><%= log.contact %></span></td>
                <td data-label="Message"><span class="msg-text"><%= log.message %></span></td>
                <td data-label="Time"><span class="time-text"><%= new Date(log.createdAt).toLocaleString() %></span></td>
                <td data-label="Approval Status">
                  <% if (log.approvalStatus === 'approved' && log.type === 'success') { %>
                  <span class="badge badge-success">Approved</span>
                  <% } else if (log.approvalStatus === 'rejected' || log.type === 'failed') { %>
                  <span class="badge badge-danger">Rejected</span>
                  <% } else if (log.approvalStatus === 'pending') { %>
                  <form action="/register/admin/approve-user?code=<%= log.code %>&role=<%= log.role %>" method="POST">
                    <button type="submit">Approve</button>
                  </form>
                  <% } else { %>
                  <span class="badge badge-success">--/--</span>
                  <% } %>
                </td>
              </tr>
              <% }) %>
              <% } else { %>
              <tr>
                <td colspan="9" style="text-align:center; color: var(--text-muted);">No registration activity yet.</td>
              </tr>
              <% } %>
            </tbody>
          </table>
        </div>

        <div class="active-employee-session-log" id="active-employee-session-log">
          <button id="active-employee-cancel-btn">Go Back</button>
          <div class="log-table-header">
            <h2>Active employee sessions</h2>
          </div>
          <table class="log-table">
            <thead>
              <tr>
                <th>Session Code</th>
                <th>Shift</th>
                <th>Type</th>
                <th>Started At</th>
                <th>Expires At</th>
              </tr>
            </thead>
            <tbody>
              <% if (activeEmployeeSessions && activeEmployeeSessions.length > 0) { %>
              <% activeEmployeeSessions.forEach(session => { %>
              <tr>
                <td data-label="Session Code">
                  <span class="id-text"><%= session.sessionCode %></span>
                </td>
                <td data-label="Shift">
                  <span class="role-pill"><%= session.shift %></span>
                </td>
                <td data-label="Type">
                  <span class="badge <%= session.type === 'check-in' ? 'badge-success' : 'badge-warning' %>">
                    <%= session.type %>
                  </span>
                </td>
                <td data-label="Started At">
                  <span class="time-text"><%= new Date(session.createdAt).toLocaleString() %></span>
                </td>
                <td data-label="Expires At">
                  <span class="time-text"><%= new Date(session.expiresAt).toLocaleString() %></span>
                </td>
              </tr>
              <% }) %>
              <% } else { %>
              <tr>
                <td colspan="5" style="text-align:center; color: var(--text-muted);">No active sessions.</td>
              </tr>
              <% } %>
            </tbody>
          </table>
        </div>

        <div class="active-student-session-log" id="active-student-session-log">
          <button id="active-student-cancel-btn">Go Back</button>
          <div class="log-table-header">
            <h2>Active student sessions</h2>
          </div>
          <table class="log-table">
            <thead>
              <tr>
                <th>Session Code</th>
                <th>Department</th>
                <th>Subject</th>
                <th>Joined</th>
                <th>Started At</th>
                <th>Expires At</th>
              </tr>
            </thead>
            <tbody>
              <% if (activeStudentSessions && activeStudentSessions.length > 0) { %>
              <% activeStudentSessions.forEach(session => { %>
              <tr>
                <td data-label="Session Code">
                  <span class="id-text"><%= session.sessionCode %></span>
                </td>
                <td data-label="Department">
                  <span class="role-pill"><%= session.department %></span>
                </td>
                <td data-label="Subject">
                  <span class="msg-text"><%= session.subject || '—' %></span>
                </td>
                <td data-label="Joined">
                  <span class="badge badge-success"><%= session.joined.length %> joined</span>
                </td>
                <td data-label="Started At">
                  <span class="time-text"><%= new Date(session.createdAt).toLocaleString() %></span>
                </td>
                <td data-label="Expires At">
                  <span class="time-text"><%= new Date(session.expiresAt).toLocaleString() %></span>
                </td>
              </tr>
              <% }) %>
              <% } else { %>
              <tr>
                <td colspan="6" style="text-align:center; color: var(--text-muted);">No active sessions.</td>
              </tr>
              <% } %>
            </tbody>
          </table>
        </div>

        <div class="employee-attendance-history-log" id="employee-attendance-history-log">
          <button id="employee-history-cancel-btn">Go Back</button>
          <div class="log-table-header">
            <h2>Employee attendance history</h2>
          </div>
          <table class="log-table">
            <thead>
              <tr>
                <th></th>
                <th>Session Code</th>
                <th>Shift</th>
                <th>Employees</th>
                <th>Date</th>
              </tr>
            </thead>
            <tbody>
              <% if (employeeHistory && employeeHistory.length > 0) { %>
              <% employeeHistory.forEach((session, i) => { %>

              <tr class="session-row" onclick="toggleHistoryRow('emp-history-<%= i %>')">
                <td data-label=""><span class="expand-icon" id="emp-history-icon-<%= i %>">▶</span></td>
                <td data-label="Session Code"><span class="id-text"><%= session.sessionCode %></span></td>
                <td data-label="Shift"><span class="role-pill"><%= session.shift %></span></td>
                <td data-label="Employees"><span class="badge badge-success"><%= session.history.length %></span></td>
                <td data-label="Date"><span class="time-text"><%= new Date(session.createdAt).toLocaleString() %></span></td>
              </tr>

              <tr class="history-detail-row" id="emp-history-<%= i %>" style="display: none;">
                <td colspan="5">
                  <% if (session.history.length === 0) { %>
                  <p class="msg-text">No entries for this session.</p>
                  <% } else { %>
                  <% session.history.forEach(entry => { %>
                  <p class="history-entry-text nav-links-property">
                    <span class="name-text"><%= entry.name %></span>
                    <span class="msg-text"> with code </span>
                    <span class="id-text"><%= entry.code %></span>
                    <span class="msg-text"> checked in at </span>
                    <span class="time-text"><%= entry.checkIn ? new Date(entry.checkIn).toLocaleString() : '—' %></span>
                    <% if (entry.checkOut) { %>
                    <span class="msg-text"> and checked out at </span>
                    <span class="time-text"><%= new Date(entry.checkOut).toLocaleString() %></span>
                    <% } else { %>
                    <span class="badge badge-warning" style="margin-left: 4px;">no checkout</span>
                    <% } %>
                  </p>
                  <% }) %>
                  <% } %>
                </td>
              </tr>

              <% }) %>
              <% } else { %>
              <tr>
                <td colspan="5" style="text-align:center; color: var(--text-muted);">No attendance history yet.</td>
              </tr>
              <% } %>
            </tbody>
          </table>
        </div>

        <div class="student-attendance-history-log" id="student-attendance-history-log">
          <button id='student-history-cancel-btn'>Go Back</button>
          <div class="log-table-header">
            <h2>Student attendance history</h2>
          </div>
          <table class="log-table">
            <thead>
              <tr>
                <th></th>
                <th>Session Code</th>
                <th>Subject</th>
                <th>Department</th>
                <th>Students</th>
                <th>Date</th>
              </tr>
            </thead>
            <tbody>
              <% if (studentHistory && studentHistory.length > 0) { %>
              <% studentHistory.forEach((session, i) => { %>
              <tr class="session-row" onclick="toggleHistoryRow('std-history-<%= i %>')">
                <td data-label=""><span class="expand-icon" id="std-history-icon-<%= i %>">▶</span></td>
                <td data-label="Session Code"><span class="id-text"><%= session.sessionCode %></span></td>
                <td data-label="Subject"><span class="msg-text"><%= session.subject || '—' %></span></td>
                <td data-label="Department"><span class="role-pill"><%= session.department %></span></td>
                <td data-label="Students"><span class="badge badge-success"><%= session.history.length %></span></td>
                <td data-label="Date"><span class="time-text"><%= new Date(session.createdAt).toLocaleString() %></span></td>
              </tr>
              <tr class="history-detail-row" id="std-history-<%= i %>" style="display: none;">
                <td colspan="6">
                  <% if (session.history.length === 0) { %>
                  <p class="msg-text">No entries for this session.</p>
                  <% } else { %>
                  <% session.history.forEach(entry => { %>
                  <p class="history-entry-text">
                    <span class="name-text"><%= entry.name %></span>
                    <span class="msg-text"> with code </span>
                    <span class="id-text"><%= entry.code %></span>
                    <span class="msg-text"> attended on </span>
                    <span class="time-text"><%= entry.date ? new Date(entry.date).toLocaleString() : '—' %></span>
                    <% if (entry.isMarked) { %>
                    <span class="badge badge-success" style="margin-left: 4px;">marked</span>
                    <% } else { %>
                    <span class="badge badge-warning" style="margin-left: 4px;">not marked</span>
                    <% } %>
                  </p>
                  <% }) %>
                  <% } %>
                </td>
              </tr>
              <% }) %>
              <% } else { %>
              <tr>
                <td colspan="6" style="text-align:center; color: var(--text-muted);">No attendance history yet.</td>
              </tr>
              <% } %>
            </tbody>
          </table>
        </div>

        <div class="student-summary-log" id="student-summary-log">
          <button id="student-summary-cancel-btn">Go Back</button>
          <div class="log-table-header">
            <h2>Student attendance summary</h2>
          </div>
          <table class="log-table">
            <thead>
              <tr>
                <th></th>
                <th>Name</th>
                <th>Code</th>
                <th>Department</th>
                <th>Month</th>
                <th>Subjects</th>
              </tr>
            </thead>
            <tbody>
              <% if (studentSummaryGrouped && studentSummaryGrouped.length > 0) { %>
              <% studentSummaryGrouped.forEach((student, i) => { %>
              <tr class="session-row" onclick="toggleHistoryRow('std-summary-<%= i %>')">
                <td data-label=""><span class="expand-icon" id="std-summary-icon-<%= i %>">▶</span></td>
                <td data-label="Name"><span class="name-text"><%= student.name %></span></td>
                <td data-label="Code"><span class="id-text"><%= student.code %></span></td>
                <td data-label="Department"><span class="role-pill"><%= student.department %></span></td>
                <td data-label="Month"><span class="time-text"><%= student.month %></span></td>
                <td data-label="Subjects"><span class="badge badge-success"><%= student.subjects.length %></span></td>
              </tr>
              <tr class="history-detail-row" id="std-summary-<%= i %>" style="display: none;">
                <td colspan="6">
                  <% student.subjects.forEach(sub => { %>
                  <p class="history-entry-text">
                    <span class="name-text"><%= sub.subject %></span>
                    <span class="msg-text"> — attended </span>
                    <span class="name-text"><%= sub.attended %></span>
                    <span class="msg-text"> of </span>
                    <span class="name-text"><%= sub.total %></span>
                    <span class="msg-text"> classes — </span>
                    <span class="badge <%= sub.percentage >= 75 ? 'badge-success' : sub.percentage >= 50 ? 'badge-warning' : 'badge-danger' %>">
                      <%= sub.percentage %>%
                    </span>
                  </p>
                  <% }) %>
                </td>
              </tr>
              <% }) %>
              <% } else { %>
              <tr>
                <td colspan="6" style="text-align:center; color: var(--text-muted);">No summary data yet.</td>
              </tr>
              <% } %>
            </tbody>
          </table>
        </div>

        <div class="employee-summary-log" id="employee-summary-log">
          <button id="employee-summary-cancel-btn">Go Back</button>
          <div class="log-table-header">
            <h2>Employee attendance summary</h2>
          </div>
          <table class="log-table">
            <thead>
              <tr>
                <th>Name</th>
                <th>Code</th>
                <th>Designation</th>
                <th>Shift</th>
                <th>Month</th>
                <th>Attended</th>
                <th>Total</th>
                <th>Percentage</th>
              </tr>
            </thead>
            <tbody>
              <% if (employeeSummary && employeeSummary.length > 0) { %>
              <% employeeSummary.forEach(entry => { %>
              <tr>
                <td data-label="Name"><span class="name-text"><%= entry.name %></span></td>
                <td data-label="Code"><span class="id-text"><%= entry.code %></span></td>
                <td data-label="Department"><span class="role-pill"><%= entry.department %></span></td>
                <td data-label="Shift"><span class="role-pill"><%= entry.shift %></span></td>
                <td data-label="Month"><span class="time-text"><%= entry.month %></span></td>
                <td data-label="Attended"><span class="name-text"><%= entry.attended %></span></td>
                <td data-label="Total"><span class="msg-text"><%= entry.total %></span></td>
                <td data-label="Percentage">
                  <span class="badge <%= entry.percentage >= 75 ? 'badge-success' : entry.percentage >= 50 ? 'badge-warning' : 'badge-danger' %>">
                    <%= entry.percentage %>%
                  </span>
                </td>
              </tr>
              <% }) %>
              <% } else { %>
              <tr>
                <td colspan="8" style="text-align:center; color: var(--text-muted);">No summary data yet.</td>
              </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </section>
  </main>
  <footer>
    <div class="foot-content">
      <div class="foot1">
